# RS WaybillService credentials
# Copy this file to .env and fill in your values.

# Service user credentials (required for most endpoints)
RS_SERVICE_USERNAME=
RS_SERVICE_PASSWORD=

# Tenant (declarant portal) credentials (required for update_service_user and related)
RS_TENANT_USERNAME=
RS_TENANT_PASSWORD=

