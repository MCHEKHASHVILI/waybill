{
    "name": "mchekhashvili/rs-waybill",
    "description": "RS Waybill api service implementation",
    "authors": [
        {
            "name": "MCHEKHASHVILI",
            "email": "m.chekhashvili@gmail.com"
        }
    ],
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Mchekhashvili\\RsWaybill\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "saloonphp/saloon": "^3.0",
        "saloonphp/xml-wrangler": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "symfony/var-dumper": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "scripts": {
        "pest": "./vendor/bin/pest",
        "pest:unit": "./vendor/bin/pest tests/Unit/Requests/Mock",
        "pest:integration": "./vendor/bin/pest tests/Unit/Requests --filter='^(?!.*Mock)'"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
